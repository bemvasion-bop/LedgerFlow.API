{
  "info": {
    "name": "SpendSync Database Seeding",
    "description": "API endpoints for seeding demo data in SpendSync",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Seed Demo Data",
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "http://localhost:5256/api/seed/demo-data",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5256",
          "path": ["api", "seed", "demo-data"]
        },
        "description": "Seeds the database with comprehensive demo data:\n- 8 companies (4 Starter, 4 Business)\n- 30-40 users with realistic Filipino names\n- 100-150 expenses with varied statuses\n- Receipts, approvals, audit logs, notifications\n\nNote: BrightPath Logistics is seeded with only 9 users for testing the 10-user Starter Plan limit."
      },
      "response": []
    },
    {
      "name": "Get Database Statistics",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:5256/api/seed/stats",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5256",
          "path": ["api", "seed", "stats"]
        },
        "description": "Returns current database statistics including:\n- Total counts for all entities\n- Expense breakdown by status\n- Company breakdown by plan"
      },
      "response": []
    },
    {
      "name": "Clear Demo Data",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "http://localhost:5256/api/seed/clear-demo-data",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5256",
          "path": ["api", "seed", "clear-demo-data"]
        },
        "description": "⚠️ WARNING: This will delete all demo data!\n\nDeletes:\n- Notifications\n- Audit logs\n- Approvals\n- Receipts\n- Expenses\n- Users (except SuperAdmin)\n- Departments\n- Companies (except Demo Company)\n\nUse this to reset the database before re-seeding."
      },
      "response": []
    },
    {
      "name": "Login - NovaCore Admin",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"maria.santos@novacoresolutionsinc.com\",\n  \"password\": \"Test@123\"\n}"
        },
        "url": {
          "raw": "http://localhost:5256/api/auth/login",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5256",
          "path": ["api", "auth", "login"]
        },
        "description": "Login as Admin from NovaCore Solutions (Starter Plan)\n\nNote: Actual email will vary based on seeded data. Check seeding output for exact emails."
      },
      "response": []
    },
    {
      "name": "Login - BrightPath Admin",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"[admin-email]@brightpathlogistics.com\",\n  \"password\": \"Test@123\"\n}"
        },
        "url": {
          "raw": "http://localhost:5256/api/auth/login",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5256",
          "path": ["api", "auth", "login"]
        },
        "description": "Login as Admin from BrightPath Logistics (Starter Plan - 9 users)\n\nUse this company to test the 10-user limit.\n\nNote: Replace [admin-email] with actual email from seeding output."
      },
      "response": []
    },
    {
      "name": "Get All Companies",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "http://localhost:5256/api/superadmin/companies",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5256",
          "path": ["api", "superadmin", "companies"]
        },
        "description": "Get list of all companies (SuperAdmin only)\n\nUse this to see all seeded companies and their details."
      },
      "response": []
    },
    {
      "name": "Get Company Users",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "http://localhost:5256/api/admin/users",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5256",
          "path": ["api", "admin", "users"]
        },
        "description": "Get all users in the logged-in admin's company\n\nUse this to verify user count for Starter Plan testing."
      },
      "response": []
    },
    {
      "name": "Get All Expenses",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "http://localhost:5256/api/expenses?pageSize=100",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5256",
          "path": ["api", "expenses"],
          "query": [
            {
              "key": "pageSize",
              "value": "100"
            }
          ]
        },
        "description": "Get all expenses for the logged-in user's company\n\nUse this to verify seeded expenses."
      },
      "response": []
    },
    {
      "name": "Get Audit Logs",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "http://localhost:5256/api/audit/logs?pageSize=100",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5256",
          "path": ["api", "audit", "logs"],
          "query": [
            {
              "key": "pageSize",
              "value": "100"
            }
          ]
        },
        "description": "Get audit logs for the logged-in user's company\n\nUse this to verify seeded audit logs."
      },
      "response": []
    },
    {
      "name": "Create 10th User (BrightPath)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"firstName\": \"Test\",\n  \"lastName\": \"Employee\",\n  \"email\": \"test.employee@brightpathlogistics.com\",\n  \"password\": \"Test@123\",\n  \"roleId\": 4,\n  \"phone\": \"+639171234567\"\n}"
        },
        "url": {
          "raw": "http://localhost:5256/api/admin/users",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5256",
          "path": ["api", "admin", "users"]
        },
        "description": "Create the 10th user in BrightPath Logistics (Starter Plan)\n\nThis should SUCCEED as it's within the 10-user limit.\n\nNote: Login as BrightPath admin first and use the token."
      },
      "response": []
    },
    {
      "name": "Create 11th User (BrightPath) - Should Fail",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"firstName\": \"Extra\",\n  \"lastName\": \"Employee\",\n  \"email\": \"extra.employee@brightpathlogistics.com\",\n  \"password\": \"Test@123\",\n  \"roleId\": 4,\n  \"phone\": \"+639171234568\"\n}"
        },
        "url": {
          "raw": "http://localhost:5256/api/admin/users",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5256",
          "path": ["api", "admin", "users"]
        },
        "description": "Try to create the 11th user in BrightPath Logistics (Starter Plan)\n\nThis should FAIL with error:\n\"User limit reached. Your Starter plan supports 10 users maximum. Upgrade to Business for unlimited users.\"\n\nNote: Run this AFTER creating the 10th user."
      },
      "response": []
    }
  ],
  "variable": [
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ]
}
